    t = _get_task('JJC-TEST-E2E-09')
    assert t is not None
    assert t['state'] == 'Done', f"仍应为Done: {t['state']}"


# ── 支持直接运行 python3 tests/test_e2e_kanban.py
if __name__ == '__main__':
    sys.exit(pytest.main([__file__, '-v']))
