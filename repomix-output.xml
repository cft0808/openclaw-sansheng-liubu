# ── TEST 6: 传旨前缀剥离
def test_prefix_stripped():
    cmd_create('JJC-TEST-E2E-06', '传旨：帮我写技术博客文章关于智能体架构', 'Zhongshu', '中书省', '中书令')
    t = _get_task('JJC-TEST-E2E-06')
    assert t is not None, "任务应被创建"
